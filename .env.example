# Pastoreio HUIOS — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com valores reais.
# NUNCA commit .env.local no repositório.

# ============================================================
# Supabase
# ============================================================

# URL do projeto Supabase (desenvolvimento local ou projeto remoto)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Chave anon pública (segura para expor no browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Chave service_role (NUNCA expor no browser — apenas server-side)
# Usada apenas em lib/supabase/server.ts
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# Aplicação
# ============================================================

# URL base da aplicação (sem barra final)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ambiente: development | staging | production
NODE_ENV=development

# ============================================================
# IMPORTANTE
# ============================================================
# - NEXT_PUBLIC_* são expostas ao browser — usar apenas valores seguros
# - SUPABASE_SERVICE_ROLE_KEY é secreta — nunca em variáveis NEXT_PUBLIC_
# - Em produção, configurar estas variáveis no dashboard da Vercel
# - Nunca usar dados reais até que autenticação e RLS estejam validados
